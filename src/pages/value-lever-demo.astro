async function runAnalysis() {
  const errorEl = document.getElementById('error-message');
  errorEl.classList.remove('visible');

  // Validate
  if (pasteMode) {
    const transcript = document.getElementById('transcript-input').value.trim();
    if (transcript.length < 100) {
      errorEl.textContent = 'Transcript must be at least 100 characters. Paste a full conversation for meaningful analysis.';
      errorEl.classList.add('visible');
      return;
    }
    if (transcript.length > 50000) {
      errorEl.textContent = 'Transcript is too long (max 50,000 characters). Try trimming to the key portion of the conversation.';
      errorEl.classList.add('visible');
      return;
    }
  } else if (!selectedSample) {
    errorEl.textContent = 'Select a call above to analyze.';
    errorEl.classList.add('visible');
    return;
  }

  // Show progress
  document.getElementById('demo-setup').style.display = 'none';
  const progress = document.getElementById('progress');
  progress.classList.add('active');
  document.getElementById('results').classList.remove('active');

  const bar = document.getElementById('progress-bar');
  const status = document.getElementById('progress-status');
  bar.style.width = '15%';
  status.textContent = 'Applying the CFO Test to every moment in the call...';

  // If sample, use demo data with simulated delay
  if (!pasteMode && selectedSample && DEMO_RESULTS[selectedSample]) {
    const steps = [
      { pct: '35%', msg: 'Evaluating rep responses to each value lever...' },
      { pct: '60%', msg: 'Generating urgency messages with customer numbers...' },
      { pct: '85%', msg: 'Compiling scorecard and recommendations...' },
      { pct: '100%', msg: 'Complete' }
    ];
    let i = 0;
    const interval = setInterval(() => {
      if (i < steps.length) {
        bar.style.width = steps[i].pct;
        status.textContent = steps[i].msg;
        i++;
      } else {
        clearInterval(interval);
        setTimeout(() => {
          progress.classList.remove('active');
          renderResults(DEMO_RESULTS[selectedSample]);
        }, 400);
      }
    }, 700);
    return;
  }

  // Paste mode — call the real API
  const transcript = document.getElementById('transcript-input').value.trim();

  const progressInterval = setInterval(() => {
    const current = parseFloat(bar.style.width);
    if (current < 85) {
      bar.style.width = (current + Math.random() * 8) + '%';
    }
    if (current > 30 && current < 50) {
      status.textContent = 'Evaluating rep responses to each value lever...';
    } else if (current > 50 && current < 70) {
      status.textContent = 'Generating urgency messages with customer numbers...';
    } else if (current > 70) {
      status.textContent = 'Compiling scorecard and recommendations...';
    }
  }, 800);

  try {
    const response = await fetch('https://app.letsponder.it/api/public/value-lever-demo', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ transcript })
    });

    clearInterval(progressInterval);

    if (!response.ok) {
      const err = await response.json().catch(() => ({ error: 'Analysis failed' }));
      throw new Error(err.error || 'Analysis failed');
    }

    const raw = await response.json();

    // API returns { analysis: "<json string>", success, model, usage }
    let data;
    if (raw.analysis && typeof raw.analysis === 'string') {
      const cleaned = raw.analysis.replace(/^```(?:json)?\s*\n?/i, '').replace(/\n?```\s*$/i, '').trim();
      data = JSON.parse(cleaned);
    } else if (raw.levers) {
      data = raw;
    } else {
      data = raw.data || raw.result || raw;
    }

    bar.style.width = '100%';
    status.textContent = 'Complete';

    setTimeout(() => {
      progress.classList.remove('active');
      renderResults(data);
    }, 400);

  } catch (err) {
    clearInterval(progressInterval);
    progress.classList.remove('active');
    document.getElementById('demo-setup').style.display = 'block';
    errorEl.textContent = err.message || 'Something went wrong. Please try again.';
    errorEl.classList.add('visible');
  }
}

function renderResults(data) {
  const results = document.getElementById('results');
  const content = document.getElementById('results-content');
  results.classList.add('active');

  let html = '';

  // Summary card
  const s = data.summary;
  const strengthClass = s.overallStrength === 'Strong' ? 'emerald' :
    s.overallStrength === 'Moderate' ? 'amber' :
    s.overallStrength === 'Weak' ? 'rose' : 'text-muted';
  const cfoClass = s.cfoReady === 'Yes' ? 'emerald' :
    s.cfoReady === 'Partially' ? 'amber' : 'rose';

  html += `<div class="summary-card">
    <div class="summary-badges">
      <span class="summary-badge" style="background:var(--${strengthClass}-dim,var(--surface-recessed));color:var(--${strengthClass},var(--text-muted))">
        ${esc(s.overallStrength)} Evidence
      </span>
      <span class="summary-badge" style="background:var(--${cfoClass}-dim,var(--surface-recessed));color:var(--${cfoClass},var(--text-muted))">
        CFO-Ready: ${esc(s.cfoReady)}
      </span>
      <span class="summary-badge" style="background:var(--accent-dim);color:var(--accent)">
        ${data.levers.length} Value Lever${data.levers.length !== 1 ? 's' : ''}
      </span>
    </div>
    <div class="summary-explanation">${esc(s.cfoReadyExplanation)}</div>
    <div class="summary-recommendation">
      <div class="summary-recommendation-label">Top Recommendation</div>
      <p>${esc(s.topRecommendation)}</p>
    </div>
  </div>`;

  // Lever cards
  data.levers.forEach(lever => {
    const typeLabel = lever.type.replace(/_/g, ' ');
    const isQuantified = lever.strength === 'Quantified';

    let repBadgeClass, repBadgeText;
    if (lever.repCaught.startsWith('Yes — Strong')) {
      repBadgeClass = 'rep-badge--strong'; repBadgeText = 'Caught — Strong';
    } else if (lever.repCaught.startsWith('Yes — Moderate') || lever.repCaught.startsWith('Yes')) {
      repBadgeClass = 'rep-badge--moderate'; repBadgeText = 'Caught — Moderate';
    } else {
      repBadgeClass = 'rep-badge--missed'; repBadgeText = 'Missed';
    }

    html += `<div class="lever-card">
      <div class="lever-header">
        <div class="lever-title">${esc(lever.title)}</div>
        <div class="lever-badges">
          <span class="lever-badge lever-badge--type">${esc(typeLabel)}</span>
          <span class="lever-badge ${isQuantified ? 'lever-badge--quantified' : 'lever-badge--unquantified'}">${esc(lever.strength)}</span>
        </div>
      </div>
      <div class="lever-body">
        <div class="lever-quote">${esc(lever.customerQuote)}</div>
        <div class="lever-cfo-impact"><strong>CFO Impact:</strong> ${esc(lever.cfoImpact)}</div>

        <div class="rep-scorecard">
          <div class="rep-scorecard-header">
            <span class="rep-scorecard-label">Rep Scorecard</span>
            <span class="rep-badge ${repBadgeClass}">${repBadgeText}</span>
          </div>
          <div class="rep-analysis">${esc(lever.repAnalysis)}</div>
          <div class="rep-recommendation">${esc(lever.repRecommendation)}</div>
        </div>

        <div class="urgency-section">
          <div class="urgency-label">Urgency Message</div>
          <div class="urgency-message">${esc(lever.urgencyMessage)}</div>
          <div class="urgency-timing">${esc(lever.urgencyTiming)}</div>
        </div>
      </div>
    </div>`;
  });

  content.innerHTML = html;
  results.scrollIntoView({ behavior: 'smooth' });
}

function esc(str) {
  if (!str) return '';
  const div = document.createElement('div');
  div.textContent = str;
  return div.innerHTML;
}

// Reset to show setup
function resetDemo() {
  document.getElementById('demo-setup').style.display = 'block';
  document.getElementById('progress').classList.remove('active');
  document.getElementById('results').classList.remove('active');
}
</script>
